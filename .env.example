# 应用升级系统 - 环境变量示例
# 复制为 .env 后按需修改：cp .env.example .env

# ---------- 服务 ----------
# 监听地址，0.0.0.0 表示所有网卡
HOST=0.0.0.0
# 监听端口（避免 6000、6666 等浏览器不安全端口，建议 5000/8080/8000）
PORT=5000
# 是否开启调试模式（true/false）
DEBUG=true

# ---------- 数据库 ----------
# SQLite 数据库文件路径，留空则使用项目内 data/upgrade.db
# DATABASE=/var/lib/upgrade/upgrade.db

# ---------- 上传 ----------
# 上传文件根目录，留空则使用项目内 uploads/
# UPLOAD_ROOT=/data/upgrade/uploads

# ---------- JWT 登录 ----------
# 密钥，生产环境务必修改
SECRET_KEY=upgrade-system-secret-key-change-in-production
# 算法，一般不需改
JWT_ALGORITHM=HS256
# Token 有效天数
JWT_EXPIRE_DAYS=7

# ---------- 清理 ----------
# 默认“保留最近 N 个月”的清理配置
DEFAULT_CLEANUP_MONTHS=3

# ---------- 默认管理员 ----------
# 仅首次初始化数据库时创建；若库中已有用户则不会覆盖
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin2026

# ---------- API Token（curl 上传） ----------
# 用于 /api/upload-by-token 接口，脚本/CI 通过 curl 上传升级包；留空则禁用该接口
# API_TOKEN=your-secret-token-here
